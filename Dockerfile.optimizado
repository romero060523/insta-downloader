FROM node:18-slim

WORKDIR /app

COPY package.json ./

RUN npm install --only=production

COPY . .

RUN apt-get update && \
    apt-get install -y python3 python3-pip ffmpeg && \
    pip3 install yt-dlp --break-system-packages && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

EXPOSE 3000

CMD ["node", "app.js"]
